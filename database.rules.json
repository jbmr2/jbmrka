{
  "rules": {
    "matches": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["createdAt", "tournamentId", "ownerId", "updatedAt"]
    },
    "tournaments": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["ownerId"]
    },
    "teams": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["tournamentId", "ownerId"]
    },
    "players": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["teamId", "ownerId"]
    },
    "users": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
